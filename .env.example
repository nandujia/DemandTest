# 智测AI (Testify AI) 环境变量配置
# Version: 3.1.0-dev

# 应用配置
APP_NAME=智测AI (Testify AI)
APP_VERSION=3.1.0-dev
DEBUG=true

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=./logs

# 存储配置
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports
DATA_DIR=./data
CONFIG_DIR=./data/config
SESSION_DIR=./data/sessions

# 爬虫配置
CRAWLER_TIMEOUT=60
CRAWLER_HEADLESS=true
PAGE_LOAD_TIMEOUT_MS=3000

# LLM 配置
# API 类型: glm, gpt, qwen, ernie, custom
LLM_API_TYPE=glm
LLM_MODEL_NAME=glm-4
LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# 知识库配置
KB_ENABLED=true
KB_STORAGE_DIR=./data/knowledge

# 学习系统配置
LEARNING_ENABLED=true
LEARNING_STORAGE_DIR=./data/learning

# 会话配置
SESSION_TIMEOUT=3600
SESSION_MAX_HISTORY=50

# CORS配置（多个源用逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
